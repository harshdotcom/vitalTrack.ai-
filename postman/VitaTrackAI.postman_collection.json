    "_postman_id": "8c5a971d-f993-4aaf-99d4-54f07b087945",
    "name": "VitaTrack AI API",
    "description": "Simple Postman collection for the VitaTrack AI backend. Change the `baseUrl` collection variable to switch between local and Render.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8081/api/v1"
    },
    {
      "key": "localBaseUrl",
      "value": "http://localhost:8081/api/v1"
    },
    {
      "key": "renderBaseUrl",
      "value": "https://vitaltrack-ai.onrender.com/api/v1"
    },
    {
      "key": "authToken",
      "value": ""
    },
    {
      "key": "email",
      "value": "user@example.com"
    },
    {
      "key": "password",
      "value": "Password123"
    },
    {
      "key": "otp",
      "value": "123456"
    },
    {
      "key": "googleToken",
      "value": ""
    },
    {
      "key": "fileId",
      "value": ""
